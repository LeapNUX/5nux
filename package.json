{
  "name": "testing-hub",
  "version": "0.0.1",
  "description": "Generate auditor-ready test artifacts from markdown test plans and Playwright evidence.",
  "private": false,
  "license": "Apache-2.0",
  "author": "Chu Ling",
  "repository": {
    "type": "git",
    "url": "https://github.com/StillNotBald/testing-hub.git"
  },
  "homepage": "https://github.com/StillNotBald/testing-hub#readme",
  "bugs": {
    "url": "https://github.com/StillNotBald/testing-hub/issues"
  },
  "keywords": [
    "testing",
    "audit",
    "compliance",
    "playwright",
    "soc2",
    "nist",
    "owasp",
    "wcag",
    "test-report",
    "evidence",
    "traceability"
  ],
  "type": "module",
  "bin": {
    "testing-hub": "bin/testing-hub.mjs"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "bin/",
    "dist/",
    "templates/",
    "docs/"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:e2e": "playwright test",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint --fix . && prettier --write .",
    "prepublishOnly": "npm run build && npm test && npm run lint"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "exceljs": "^4.4.0",
    "gray-matter": "^4.0.3",
    "marked": "^12.0.0",
    "sharp": "^0.33.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0"
  }
}
